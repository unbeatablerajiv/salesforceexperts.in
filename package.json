{
  "name": "salesforceexperts.in",
  "version": "1.0.0",
  "private": true,
  "description": "Personal website running on Gatsby, React, and Node.js.",
  "author": "Rajiv Singh <rajiv4som1@gmail.com>",
  "repository": "git@github.com:unbeatablerajiv/salesforceexperts.in",
  "license": "MIT",
  "main": "n/a",
  "keywords": [
    "rajiv singh",
    "development",
    "dev",
    "tutorials",
    "tech",
    "articles",
    "blog"
  ],
  "scripts": {
    "develop": "gatsby develop",
    "dev": "yarn run develop",
    "serve": "gatsby serve",
    "build": "gatsby build",
    "build:pp": "gatsby build --prefix-paths",
    "build:gh": "yarn run clean && yarn run build:pp && gh-pages -d public",
    "clean": "rm -rf public && gatsby clean && rm -rf .cache",
    "lint:js": "eslint --ext .js,.jsx .",
    "lint:md": "remark content/posts/",
    "format:js": "prettier '**/*.{js,jsx}' --write",
    "check": "yarn upgrade-interactive --latest"
  },
  "remarkConfig": {
    "plugins": [
      "remark-preset-lint-recommended"
    ]
  },
  "dependencies": {
    "@mdx-js/react": "^2.3.0",
    "@weknow/gatsby-remark-twitter": "^0.2.3",
    "axios": "^1.4.0",
    "date-fns": "^2.30.0",
    "gatsby": "^5.11.0",
    "gatsby-plugin-catch-links": "^5.11.0",
    "gatsby-plugin-feed": "^5.11.0",
    "gatsby-plugin-google-gtag": "^5.11.0",
    "gatsby-plugin-image": "^3.11.0",
    "gatsby-plugin-manifest": "^5.11.0",
    "gatsby-plugin-mdx": "^5.11.0",
    "gatsby-plugin-netlify": "^5.1.0",
    "gatsby-plugin-netlify-cms": "^7.11.0",
    "gatsby-plugin-nprogress": "^5.11.0",
    "gatsby-plugin-sass": "^6.11.0",
    "gatsby-plugin-sharp": "^5.11.0",
    "gatsby-plugin-sitemap": "^6.11.0",
    "gatsby-remark-autolink-headers": "^6.11.0",
    "gatsby-remark-copy-linked-files": "^6.11.0",
    "gatsby-remark-images": "^7.11.0",
    "gatsby-remark-prismjs": "^7.11.0",
    "gatsby-source-filesystem": "^5.11.0",
    "gatsby-transformer-remark": "^6.11.0",
    "gatsby-transformer-sharp": "^5.11.0",
    "install": "^0.13.0",
    "lodash": "^4.17.21",
    "lodash.kebabcase": "^4.1.1",
    "moment": "^2.29.4",
    "netlify-cms-app": "^2.15.72",
    "prismjs": "^1.29.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-github-btn": "^1.4.0",
    "react-helmet": "^6.1.0",
    "sass": "^1.65.1"
  },
  "devDependencies": {
    "babel-eslint": "^10.1.0",
    "cli-glob": "^0.1.0",
    "eslint": "^8.46.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "9.0.0",
    "eslint-plugin-import": "^2.28.0",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-react": "^7.33.1",
    "prettier": "^3.0.1",
    "remark-cli": "^11.0.0",
    "remark-preset-lint-recommended": "^6.1.3",
    "stylefmt": "^6.0.3",
    "stylelint": "^15.10.2",
    "stylelint-config-standard": "^34.0.0"
  }
}
